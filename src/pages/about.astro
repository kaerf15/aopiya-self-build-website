---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — Aopiya" description="Handcrafted leather goods from Guangzhou, shipped worldwide since 2015.">
  <section class="pt-32 pb-20 px-6 bg-bg">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs font-medium tracking-[0.25em] uppercase text-accent mb-4">Our Story</p>
      <h1 class="font-display text-5xl md:text-6xl font-normal mb-8">Where Patience<br>Meets Leather</h1>
      <p class="text-ink-secondary font-light leading-relaxed text-lg mb-12">
        Aopiya was founded in 2015 in a small workshop in Guangzhou, born from a simple belief: that the best things in life take time.
        We set out to create leather goods that would outlast trends, outlive their owners, and tell stories through every scratch and mark.
      </p>
    </div>
  </section>

  <section class="py-20 px-6 bg-bg-warm">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div>
        <img src="/images/craft.jpg" alt="Artisan crafting leather" class="w-full aspect-[4/3] object-cover">
      </div>
      <div>
        <p class="text-xs tracking-[0.25em] uppercase text-accent mb-4">The Atelier</p>
        <h2 class="font-display text-3xl font-normal mb-6">Five Artisans, One Philosophy</h2>
        <p class="text-ink-secondary font-light leading-relaxed mb-4">
          In our Guangzhou atelier, five artisans work in a former textile workshop. Each bag passes through a single pair of hands
          from start to finish — no assembly lines, no outsourcing, no shortcuts.
        </p>
        <p class="text-ink-secondary font-light leading-relaxed">
          We use only vegetable-tanned full-grain leather from certified Italian tanneries. This leather develops a rich patina
          unique to its owner, making each piece truly one of a kind.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 px-6 bg-ink text-white">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
      <div>
        <p class="font-display text-5xl font-normal text-accent-light mb-2">10+</p>
        <p class="text-white/60 text-sm tracking-wide">Years of Craft</p>
      </div>
      <div>
        <p class="font-display text-5xl font-normal text-accent-light mb-2">5</p>
        <p class="text-white/60 text-sm tracking-wide">Master Artisans</p>
      </div>
      <div>
        <p class="font-display text-5xl font-normal text-accent-light mb-2">40+</p>
        <p class="text-white/60 text-sm tracking-wide">Hours Per Piece</p>
      </div>
    </div>
  </section>
</Layout>