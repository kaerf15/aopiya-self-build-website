---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<Layout title={`${post.data.title} — Aopiya`} description={post.data.summary}>
  <article class="pt-32 pb-20 px-6 bg-bg">
    <div class="max-w-3xl mx-auto">
      <p class="text-xs text-ink-muted tracking-wide mb-4">{formatDate(post.data.date)} · {post.data.category}</p>
      <h1 class="font-display text-4xl md:text-5xl font-normal leading-tight mb-8">{post.data.title}</h1>
      <div class="aspect-[16/9] overflow-hidden bg-bg-warm mb-12">
        <img src={post.data.coverImage} alt={post.data.title} class="w-full h-full object-cover" />
      </div>
      <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:font-normal prose-p:text-ink-secondary prose-p:font-light prose-a:text-primary prose-strong:text-ink">
        <Content />
      </div>
    </div>
  </article>
</Layout>