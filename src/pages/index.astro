---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const products = await getCollection('products');
const featuredProducts = products.filter(p => p.data.featured).slice(0, 3);

const posts = await getCollection('blog');
const latestPosts = posts
  .filter(p => p.data.published)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<Layout>
  <!-- Hero -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
    <div class="absolute inset-0 bg-gradient-to-br from-[#2C1810] via-[#1C110C] to-[#0F0906]"></div>
    <div class="absolute inset-0 bg-[url('/images/hero.png')] bg-cover bg-center opacity-35"></div>
    <div class="relative z-10 text-center text-bg px-6 max-w-3xl">
      <p class="text-xs tracking-[0.25em] uppercase text-accent-light mb-6">Handcrafted in Guangzhou since 2015</p>
      <h1 class="font-display text-5xl md:text-7xl font-normal leading-tight mb-6">
        Where <em class="italic text-accent-light">Patience</em><br>Meets Leather
      </h1>
      <p class="text-lg font-light text-white/75 max-w-xl mx-auto mb-10 leading-relaxed">
        Each Aopiya piece carries the warmth of hand-selected full-grain leather, shaped by artisans who believe the best things take time.
      </p>
      <div class="flex justify-center gap-4">
        <a href="/products" class="inline-block px-10 py-4 text-xs font-medium tracking-[0.15em] uppercase bg-accent text-white border border-accent hover:bg-primary hover:border-primary transition-all">
          Explore Collection
        </a>
        <a href="#craft" class="inline-block px-10 py-4 text-xs font-medium tracking-[0.15em] uppercase bg-transparent text-white border border-white/40 hover:bg-white/10 hover:border-white/70 transition-all">
          Our Story
        </a>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/40 text-xs tracking-[0.2em] uppercase">Scroll</div>
  </section>

  <!-- Products -->
  <section class="py-32 px-6 bg-bg" id="products">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20">
        <p class="text-xs font-medium tracking-[0.25em] uppercase text-accent mb-4">The Collection</p>
        <h2 class="font-display text-4xl md:text-5xl font-normal mb-4">Made to Last a Lifetime</h2>
        <p class="text-ink-secondary font-light max-w-lg mx-auto">Every stitch intentional. Every hide tells a story. These are the pieces that get better with age.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {featuredProducts.map(product => (
          <a href={`/products/${product.data.slug}`} class="group cursor-pointer no-underline text-ink">
            <div class="relative aspect-[3/4] overflow-hidden bg-bg-warm mb-6">
              <img src={product.data.images[0]} alt={product.data.name} loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
              <span class="absolute top-4 left-4 text-xs tracking-widest uppercase px-3 py-1.5 bg-ink/80 text-white">
                {product.data.inStock ? 'In Stock' : 'Sold Out'}
              </span>
            </div>
            <h3 class="font-display text-xl font-medium mb-1">{product.data.name}</h3>
            <p class="text-[0.9375rem] text-ink-secondary font-light">${product.data.price}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Craftsmanship -->
  <section class="grid grid-cols-1 md:grid-cols-2 min-h-[600px] bg-ink text-white" id="craft">
    <div class="relative overflow-hidden min-h-[300px]">
      <img src="/images/craft.png" alt="Artisan at work" loading="lazy" class="w-full h-full object-cover" />
    </div>
    <div class="flex flex-col justify-center p-12 md:p-20">
      <p class="text-xs tracking-[0.25em] uppercase text-accent-light mb-6">Our Atelier</p>
      <h2 class="font-display text-3xl md:text-4xl font-normal leading-tight mb-6">Slow Fashion, Real Craft</h2>
      <p class="text-white/65 font-light leading-relaxed mb-8">
        In a world of fast production, we choose the opposite. Each Aopiya piece spends 40+ hours in the hands of a single artisan, from hide selection to the final burnish. We use only vegetable-tanned full-grain leather from certified Italian tanneries — leather that develops a rich patina unique to its owner's journey.
      </p>
      <a href="/about" class="inline-block self-start px-10 py-4 text-xs font-medium tracking-[0.15em] uppercase bg-transparent text-white border border-white/40 hover:bg-white/10 hover:border-white/70 transition-all">
        Meet the Artisans
      </a>
    </div>
  </section>

  <!-- Journal -->
  <section class="py-32 px-6 bg-bg" id="journal">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20">
        <p class="text-xs font-medium tracking-[0.25em] uppercase text-accent mb-4">From the Journal</p>
        <h2 class="font-display text-4xl md:text-5xl font-normal mb-4">Stories Worth Telling</h2>
        <p class="text-ink-secondary font-light max-w-lg mx-auto">Behind every piece is a story — of craft, of place, of the people who make it possible.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {latestPosts.map(post => (
          <a href={`/blog/${post.data.slug}`} class="group cursor-pointer no-underline text-ink">
            <div class="aspect-[16/10] overflow-hidden bg-bg-warm mb-5">
              <img src={post.data.coverImage} alt={post.data.title} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]" />
            </div>
            <p class="text-xs text-ink-muted tracking-wide mb-2">{formatDate(post.data.date)} · {post.data.category}</p>
            <h3 class="font-display text-lg font-medium leading-snug transition-colors group-hover:text-primary">{post.data.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="py-24 px-6 bg-bg-warm text-center">
    <h2 class="font-display text-3xl md:text-4xl font-normal mb-3">Join the Inner Circle</h2>
    <p class="text-ink-secondary font-light mb-8">Early access to new drops, stories from the atelier, and care tips from our artisans.</p>
    <form class="flex gap-3 justify-center max-w-lg mx-auto" onsubmit="event.preventDefault(); alert('Thank you for subscribing.');">
      <input type="email" placeholder="Your email address" required class="flex-1 px-5 py-4 border border-border bg-white text-sm outline-none focus:border-accent transition-colors placeholder:text-ink-muted" />
      <button type="submit" class="px-8 py-4 text-xs font-medium tracking-[0.15em] uppercase bg-accent text-white border border-accent hover:bg-primary hover:border-primary transition-all">Subscribe</button>
    </form>
  </section>
</Layout>
