---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const latestPosts = posts
  .filter(p => p.data.published)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<Layout>
  <!-- Hero -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
    <div class="absolute inset-0 bg-gradient-to-br from-[#2C1810] via-[#1C110C] to-[#0F0906]"></div>
    <div class="absolute inset-0 bg-[url('/images/hero.png')] bg-cover bg-center opacity-40"></div>
    <div class="relative z-10 text-center text-bg px-6 max-w-3xl">
      <p class="text-xs tracking-[0.25em] uppercase text-accent-light mb-6">Guangzhou · Since 1999</p>
      <h1 class="font-display text-5xl md:text-7xl font-normal leading-tight mb-6">
        Where Craft<br>Meets the World
      </h1>
      <p class="text-lg font-light text-white/75 max-w-xl mx-auto mb-10 leading-relaxed">
        For 25 years, Aopiya has crafted bags for the world's leading brands. Today, our own brands carry that legacy forward — designed for the women who shape tomorrow.
      </p>
      <div class="flex justify-center gap-4">
        <a href="#brands" class="inline-block px-10 py-4 text-xs font-medium tracking-[0.15em] uppercase bg-accent text-white border border-accent hover:bg-primary hover:border-primary transition-all">
          Explore Brands
        </a>
        <a href="/about" class="inline-block px-10 py-4 text-xs font-medium tracking-[0.15em] uppercase bg-transparent text-white border border-white/40 hover:bg-white/10 hover:border-white/70 transition-all">
          Our Story
        </a>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/40 text-xs tracking-[0.2em] uppercase">Scroll</div>
  </section>

  <!-- Brand Matrix -->
  <section class="py-32 px-6 bg-bg" id="brands">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-20">
        <p class="text-xs font-medium tracking-[0.25em] uppercase text-accent mb-4">The House of Aopiya</p>
        <h2 class="font-display text-4xl md:text-5xl font-normal mb-4">Three Brands, One Vision</h2>
        <p class="text-ink-secondary font-light max-w-xl mx-auto">Each born from a different creative impulse. Each sharing the same uncompromising standard of craftsmanship that defines Aopiya.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <!-- SUSEN -->
        <a href="/products#susen" class="group cursor-pointer no-underline text-ink">
          <div class="relative aspect-[3/4] overflow-hidden bg-bg-warm mb-6">
            <img src="/images/susen-model.png" alt="SUSEN collection" loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-ink/60 via-transparent to-transparent"></div>
            <div class="absolute bottom-6 left-6 text-white">
              <p class="text-xs tracking-[0.2em] uppercase text-accent-light mb-1">Est. 2003 · Dubai</p>
              <p class="font-display text-2xl">SUSEN</p>
            </div>
          </div>
          <h3 class="font-display text-xl font-medium mb-2">Art Meets Fashion</h3>
          <p class="text-[0.9375rem] text-ink-secondary font-light leading-relaxed">Where art becomes wearable. Bold forms, unexpected materials, and a spirit that refuses to conform. For the woman who sees fashion as self-expression.</p>
        </a>

        <!-- Chrisbella -->
        <a href="/products#chrisbella" class="group cursor-pointer no-underline text-ink">
          <div class="relative aspect-[3/4] overflow-hidden bg-bg-warm mb-6">
            <img src="/images/chrisbella-model.png" alt="Chrisbella collection" loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-ink/60 via-transparent to-transparent"></div>
            <div class="absolute bottom-6 left-6 text-white">
              <p class="text-xs tracking-[0.2em] uppercase text-accent-light mb-1">Est. 2018</p>
              <p class="font-display text-2xl">Chrisbella</p>
            </div>
          </div>
          <h3 class="font-display text-xl font-medium mb-2">Fashion Can Be Kind</h3>
          <p class="text-[0.9375rem] text-ink-secondary font-light leading-relaxed">Intelligent design meets conscious creation. Zero-fur policy, trend-aware silhouettes, and the quiet confidence of knowing your style doesn't cost the earth.</p>
        </a>

        <!-- BAGCO -->
        <a href="/products#bagco" class="group cursor-pointer no-underline text-ink">
          <div class="relative aspect-[3/4] overflow-hidden bg-bg-warm mb-6">
            <img src="/images/bagco-model.png" alt="BAGCO collection" loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-ink/60 via-transparent to-transparent"></div>
            <div class="absolute bottom-6 left-6 text-white">
              <p class="text-xs tracking-[0.2em] uppercase text-accent-light mb-1">Est. 2010</p>
              <p class="font-display text-2xl">BAGCO</p>
            </div>
          </div>
          <h3 class="font-display text-xl font-medium mb-2">The Power of Softness</h3>
          <p class="text-[0.9375rem] text-ink-secondary font-light leading-relaxed">Classic never means boring. Refined cuts, rich palettes, and the enduring elegance that transcends seasons. For the woman who leads with grace.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Craftsmanship / Atelier -->
  <section class="grid grid-cols-1 md:grid-cols-2 min-h-[600px] bg-ink text-white" id="craft">
    <div class="relative overflow-hidden min-h-[300px]">
      <img src="/images/craft.png" alt="Aopiya atelier" loading="lazy" class="w-full h-full object-cover" />
    </div>
    <div class="flex flex-col justify-center p-12 md:p-20">
      <p class="text-xs tracking-[0.25em] uppercase text-accent-light mb-6">Our Atelier</p>
      <h2 class="font-display text-3xl md:text-4xl font-normal leading-tight mb-6">25 Years of Making<br>for the World's Best</h2>
      <p class="text-white/65 font-light leading-relaxed mb-8">
        50,000 square meters. 1,000+ artisans. 60+ international brands have trusted Aopiya with their name. That same precision, that same devotion — now poured into brands we call our own.
      </p>
      <div class="grid grid-cols-2 gap-8 mb-8">
        <div>
          <p class="font-display text-3xl text-accent-light mb-1">35</p>
          <p class="text-white/50 text-sm">Design Patents</p>
        </div>
        <div>
          <p class="font-display text-3xl text-accent-light mb-1">100+</p>
          <p class="text-white/50 text-sm">Countries</p>
        </div>
        <div>
          <p class="font-display text-3xl text-accent-light mb-1">1000+</p>
          <p class="text-white/50 text-sm">Artisans</p>
        </div>
        <div>
          <p class="font-display text-3xl text-accent-light mb-1">60+</p>
          <p class="text-white/50 text-sm">Partner Brands</p>
        </div>
      </div>
      <a href="/about" class="inline-block self-start px-10 py-4 text-xs font-medium tracking-[0.15em] uppercase bg-transparent text-white border border-white/40 hover:bg-white/10 hover:border-white/70 transition-all">
        Our Story
      </a>
    </div>
  </section>

  <!-- Journal -->
  <section class="py-32 px-6 bg-bg-warm">
    <div class="max-w-7xl mx-auto">
      <div class="flex justify-between items-end mb-16">
        <div>
          <p class="text-xs font-medium tracking-[0.25em] uppercase text-accent mb-4">The Journal</p>
          <h2 class="font-display text-4xl font-normal">Stories Worth Telling</h2>
        </div>
        <a href="/blog" class="text-sm tracking-wide text-primary hover:text-ink transition-colors no-underline hidden md:block">View All &rarr;</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {latestPosts.map(post => (
          <a href={`/blog/${post.data.slug}`} class="group cursor-pointer no-underline text-ink">
            <div class="aspect-[16/10] overflow-hidden bg-bg mb-5">
              <img src={post.data.coverImage} alt={post.data.title} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]" />
            </div>
            <p class="text-xs text-ink-muted tracking-wide mb-2">{formatDate(post.data.date)} · {post.data.category}</p>
            <h3 class="font-display text-lg font-medium leading-snug transition-colors group-hover:text-primary">{post.data.title}</h3>
            <p class="text-sm text-ink-secondary font-light mt-2 line-clamp-2">{post.data.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
