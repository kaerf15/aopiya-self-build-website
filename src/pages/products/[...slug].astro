---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.data.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);
---

<Layout title={`${product.data.name} — Aopiya`} description={product.data.description}>
  <section class="pt-32 pb-20 px-6 bg-bg">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
        <!-- Images -->
        <div class="space-y-4">
          {product.data.images.map((img, i) => (
            <div class="aspect-square overflow-hidden bg-bg-warm">
              <img src={img} alt={`${product.data.name} ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'} class="w-full h-full object-cover" />
            </div>
          ))}
        </div>

        <!-- Info -->
        <div class="md:sticky md:top-24 md:self-start">
          <p class="text-xs tracking-[0.25em] uppercase text-accent mb-4">{product.data.category}</p>
          <h1 class="font-display text-4xl md:text-5xl font-normal mb-8">{product.data.name}</h1>
          <p class="text-ink-secondary font-light leading-relaxed mb-8">{product.data.description}</p>

          <div class="space-y-3 mb-10 text-sm text-ink-secondary">
            <div class="flex justify-between border-b border-border py-3">
              <span>Material</span>
              <span class="text-ink">{product.data.material}</span>
            </div>
            <div class="flex justify-between border-b border-border py-3">
              <span>Dimensions</span>
              <span class="text-ink">{product.data.dimensions}</span>
            </div>
            <div class="flex justify-between border-b border-border py-3">
              <span>Availability</span>
              <span class="text-ink">{product.data.inStock ? 'In Stock' : 'Sold Out'}</span>
            </div>
          </div>

          <button class="w-full px-10 py-4 text-xs font-medium tracking-[0.15em] uppercase bg-accent text-white border border-accent hover:bg-primary hover:border-primary transition-all cursor-pointer">
            Inquire to Order
          </button>
        </div>
      </div>

      <!-- Description -->
      <div class="mt-20 max-w-2xl">
        <Content />
      </div>
    </div>
  </section>
</Layout>
